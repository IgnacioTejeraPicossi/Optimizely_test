@model OptiDemoCms.Models.AIToolsPage
@{
    Layout = "~/Views/Shared/_PersonalLayout.cshtml";
    ViewData["Title"] = Model.Heading ?? "AI Tools";
}

<div class="personal-page ai-tools-page" data-testid="ai-tools-page">
    <div class="personal-banner">AI Tools</div>

    <div class="personal-card">
        @if (Model.MainBody != null && !Model.MainBody.IsEmpty)
        {
            @Html.PropertyFor(x => x.MainBody)
        }
        else
        {
            <h2>AI I Enjoy using</h2>
            <ol class="personal-list ai-tools-list">
                <li class="ai-tool-item">
                    <img src="@Url.Content("~/images/ai-tools/chatgpt.png")" alt="ChatGPT" class="ai-tool-icon" />
                    <a href="https://www.chatgpt.com" target="_blank" rel="noopener">AI ChatGPT / OpenAI</a>
                </li>
                <li class="ai-tool-item">
                    <img src="@Url.Content("~/images/ai-tools/TestMaster.png")" alt="Test Master" class="ai-tool-icon" />
                    <a href="https://chatgpt.com/g/g-OhCEQmCRo-test-master" target="_blank" rel="noopener">ChatGPT Agent / Test Master</a>
                </li>
                <li class="ai-tool-item">
                    <img src="@Url.Content("~/images/ai-tools/deepseek.png")" alt="DeepSeek" class="ai-tool-icon" />
                    <a href="https://www.deepseek.com/" target="_blank" rel="noopener">AI DeepSeek</a>
                </li>
                <li class="ai-tool-item">
                    <img src="@Url.Content("~/images/ai-tools/grok.png")" alt="Grok" class="ai-tool-icon" />
                    <a href="https://x.com/i/grok" target="_blank" rel="noopener">Grok / X</a>
                </li>
                <li class="ai-tool-item">
                    <img src="@Url.Content("~/images/ai-tools/Relevance-ai.jpeg")" alt="Outlier Playground" class="ai-tool-icon" />
                    <a href="https://app.outlier.ai/playground/677bd04eb826295674c4a8a9" target="_blank" rel="noopener">Outlier Playground</a>
                </li>
                <li class="ai-tool-item">
                    <img src="@Url.Content("~/images/ai-tools/meta.png")" alt="VR Meta" class="ai-tool-icon" />
                    <a href="https://www.meta.com" target="_blank" rel="noopener">VR Meta</a>
                </li>
                <li class="ai-tool-item">
                    <img src="@Url.Content("~/images/ai-tools/gemini.jpeg")" alt="Gemini" class="ai-tool-icon" />
                    <a href="https://gemini.google.com" target="_blank" rel="noopener">Gemini 2.0 Flash</a>
                </li>
                <li class="ai-tool-item">
                    <img src="@Url.Content("~/images/ai-tools/perplexity.jpeg")" alt="Perplexity" class="ai-tool-icon" />
                    <a href="https://www.perplexity.ai" target="_blank" rel="noopener">Perplexity</a>
                </li>
                <li class="ai-tool-item">
                    <img src="@Url.Content("~/images/ai-tools/Qwen2.5.jpeg")" alt="Qwen2.5" class="ai-tool-icon" />
                    <a href="https://huggingface.co/spaces/Qwen/Qwen2.5-Max-Demo" target="_blank" rel="noopener">Qwen2.5</a>
                </li>
                <li class="ai-tool-item">
                    <img src="@Url.Content("~/images/ai-tools/watsonx-ai.jpeg")" alt="watsonx-ai" class="ai-tool-icon" />
                    <a href="https://www.ibm.com/products/watsonx-ai" target="_blank" rel="noopener">watsonx-ai</a>
                </li>
                <li class="ai-tool-item">
                    <img src="@Url.Content("~/images/ai-tools/Cursor-ai.jpeg")" alt="Cursor AI" class="ai-tool-icon" />
                    <a href="https://www.cursor.com" target="_blank" rel="noopener">Cursor AI</a>
                </li>
                <li class="ai-tool-item">
                    <img src="@Url.Content("~/images/ai-tools/LMStudio.jpeg")" alt="LM Studio" class="ai-tool-icon" />
                    <a href="https://lmstudio.ai" target="_blank" rel="noopener">LM Studio</a>
                </li>
                <li class="ai-tool-item">
                    <img src="@Url.Content("~/images/ai-tools/AnythingLLM.png")" alt="Anything LLM" class="ai-tool-icon" />
                    <a href="https://anythingllm.com" target="_blank" rel="noopener">Anything LLM</a>
                </li>
            </ol>
        }
    </div>
</div>
