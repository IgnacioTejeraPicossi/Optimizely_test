@model OptiDemoCms.Models.AIToolsPage
@{
    Layout = "~/Views/Shared/_PersonalLayout.cshtml";
    ViewData["Title"] = Model.Heading ?? "AI Tools";
}

<div class="personal-page ai-tools-page" data-testid="ai-tools-page">
    <div class="personal-banner">AI Tools</div>

    <div class="personal-card">
        @if (Model.MainBody != null && !Model.MainBody.IsEmpty)
        {
            @Html.PropertyFor(x => x.MainBody)
        }
        else
        {
            <h2>AI I Enjoy using</h2>
            <ol class="personal-list ai-tools-list">
                <li class="ai-tool-item">
                    <img src="@Url.Content("~/images/ai-tools/chatgpt.png")" alt="ChatGPT" class="ai-tool-icon" />
                    <span>AI ChatGPT / OpenAI</span>
                </li>
                <li class="ai-tool-item">
                    <img src="@Url.Content("~/images/ai-tools/TestMaster.png")" alt="Test Master" class="ai-tool-icon" />
                    <span>ChatGPT Agent / Test Master</span>
                </li>
                <li class="ai-tool-item">
                    <img src="@Url.Content("~/images/ai-tools/deepseek.png")" alt="DeepSeek" class="ai-tool-icon" />
                    <span>AI DeepSeek</span>
                </li>
                <li class="ai-tool-item">
                    <img src="@Url.Content("~/images/ai-tools/grok.png")" alt="Grok" class="ai-tool-icon" />
                    <span>Grok / X</span>
                </li>
                <li class="ai-tool-item">
                    <img src="@Url.Content("~/images/ai-tools/Relevance-ai.jpeg")" alt="Outlier Playground" class="ai-tool-icon" />
                    <span>Outlier Playground</span>
                </li>
                <li class="ai-tool-item">
                    <img src="@Url.Content("~/images/ai-tools/meta.png")" alt="VR Meta" class="ai-tool-icon" />
                    <span>VR Meta</span>
                </li>
                <li class="ai-tool-item">
                    <img src="@Url.Content("~/images/ai-tools/gemini.jpeg")" alt="Gemini" class="ai-tool-icon" />
                    <span>Gemini 2.0 Flash</span>
                </li>
                <li class="ai-tool-item">
                    <img src="@Url.Content("~/images/ai-tools/perplexity.jpeg")" alt="Perplexity" class="ai-tool-icon" />
                    <span>Perplexity</span>
                </li>
                <li class="ai-tool-item">
                    <img src="@Url.Content("~/images/ai-tools/Qwen2.5.jpeg")" alt="Qwen2.5" class="ai-tool-icon" />
                    <span>Qwen2.5</span>
                </li>
                <li class="ai-tool-item">
                    <img src="@Url.Content("~/images/ai-tools/watsonx-ai.jpeg")" alt="watsonx-ai" class="ai-tool-icon" />
                    <span>watsonx-ai</span>
                </li>
            </ol>
        }
    </div>
</div>
